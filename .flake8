[flake8]
max-line-length = 88
extend-ignore = E203, E402, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    .eggs,
    *.egg,
    akash/proto/,
    tests/
per-file-ignores =
    akash/__init__.py:E402
    akash/modules/*.py:E501,F401
    akash/messages/*.py:E501,F401